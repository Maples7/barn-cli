#!/usr/bin/env node

import config from '../config.js';
const barnStarter = config.barnStarterURL;

import fs from 'fs';
import _ from 'lodash';
import shell from 'shelljs';
import yaml from 'js-yaml';
import { globSync } from 'glob';
import { minimatch } from 'minimatch';
import Debug from 'debug';
import { minify as htmlMinify } from 'html-minifier-terser';
import CleanCSS from 'clean-css';
import pug from 'pug';
import chokidar from 'chokidar';

import { exec as execCb } from 'child_process';
import { platform } from 'os';
import http from 'http';
import path from 'path';

const debug = Debug('barn-cli');

if (!shell.which('git')) {
  echoErrAndExit('Sorry, this script requires git');
}

let spec = null;

import yargs from 'yargs';
import { hideBin } from 'yargs/helpers';

const yargsInstance = yargs(hideBin(process.argv))
  .usage('Usage: barn <command>')
  .demandCommand(1, 'You must provide a valid command')
  .command(['init', 'i'], 'Initiate a barn project with folder name `barn`')
  .example('barn init', 'Initiate barn starter')
  .command(
    ['generate', 'g'],
    'Generate ultimate static website to folder `dist`'
  )
  .example('barn generate', 'Generate ultimate static website')
  .command(['server', 's'], `Watch changes of files and apply them immediately`, yargs => {
    yargs.option('port', {
      alias: 'p',
      type: 'number',
      default: 3579,
      describe: 'Port number for the dev server'
    });
  })
  .example('barn server', `Watch files' changes and apply them immediately`)
  .example('barn server -p 8080', 'Start dev server on port 8080')
  .command(['deploy', 'd'], 'Deploy to a git-based server such as Github Pages')
  .example('barn deploy', 'Deploy to a git-based server')
  .help('h')
  .alias('help', 'h')
  .version()
  .alias('v', 'version')
  .epilog(
    `Copyright ${new Date().getFullYear()}, see https://github.com/Maples7/barn for more information.`
  );
const argv = await yargsInstance.argv;

const command = argv._[0];
debug(`command: ${command}`);
switch (command) {
  case 'i':
  case 'init':
    git(`git clone ${barnStarter}`);
    const pjName = barnStarter.slice(
      barnStarter.lastIndexOf('/') + 1,
      barnStarter.lastIndexOf('.')
    );
    shell.rm('-rf', `${pjName}/.git`);
    break;
  case 'g':
  case 'generate':
    readUserConfig();
    await barnGenerate();
    break;
  case 's':
  case 'server':
    readUserConfig();
    await barnServer(argv.port);
    break;
  case 'd':
  case 'deploy':
    readUserConfig();
    await barnGenerate();
    shell.cd('dist');
    const isNewRepo = !fs.existsSync('.git');
    if (isNewRepo) {
      git('git init');
      let firstOne = true;
      _.forOwn(spec.deploy.repos, (v, k) => {
        if (firstOne) {
          git(`git remote add origin ${v}`);
          firstOne = false;
        } else {
          git(`git remote set-url --add origin ${v}`);
        }
      });
    }
    git('git add -A');
    const hasChanges = shell.exec('git diff --cached --quiet', { silent: true }).code !== 0;
    if (!hasChanges) {
      shell.echo('No changes to deploy.');
      break;
    }
    git(`git commit -m "[Barn Auto Deploy] ${new Date()}"`);
    git('git push --force origin HEAD');
    break;
  default:
    yargsInstance.showHelp();
    break;
}

// supporting functions

/**
 * print Error and exit
 */
function echoErrAndExit(msg, exit = true) {
  shell.echo(msg);
  if (exit) {
    shell.exit(1);
  }
}

/**
 * read user config
 */
function readUserConfig() {
  if (!spec) {
    spec = readYaml(config.configFileName, 'configs');
  }
  return spec;
}

/**
 * run git command
 */
function git(cmd, exit = true) {
  if (shell.exec(cmd).code !== 0) {
    echoErrAndExit(`Error: ${cmd} failed`, exit);
  }
}

/**
 * read yaml file
 */
function readYaml(fileName, action) {
  let content = null;
  try {
    debug(`Reading ${action} from ${fileName}`);
    content = yaml.load(fs.readFileSync(fileName, 'utf8'));
    debug(`your ${action}:`);
    debug(content);
  } catch (e) {
    echoErrAndExit(`Error: read configs from ${fileName} failed: ${e}`);
  }
  return content;
}

/**
 * render html template
 */
function templateRender(theme, engine, locals) {
  let htmls = [];
  switch (engine) {
    case 'pug':
      _.forOwn(locals, (pairs, name) => {
        htmls.push({
          name,
          content: pug.renderFile(`themes/${theme}/${name}.pug`, pairs)
        });
      });
      break;
    default:
      echoErrAndExit(`Error: unsupported html template engine: ${engine}`);
      break;
  }
  return htmls;
}

/**
 * get rendered html
 */
function getRenderedHtml() {
  const locals = {};
  _.forEach(spec.htmls, html => {
    locals[html] = readYaml(
      `themes/${spec.theme}/${config.contentDir}/${html}.yml`,
      `${html} content`
    ) || {};
  });

  return templateRender(spec.theme, spec.template_engine, locals);
}

/**
 * barnGenerate
 */
async function barnGenerate() {
  const htmls = getRenderedHtml();
  const cacheBust = Date.now();
  // clean dist but preserve .git for incremental deploy
  if (fs.existsSync('dist')) {
    for (const entry of fs.readdirSync('dist')) {
      if (entry === '.git') continue;
      shell.rm('-rf', `dist/${entry}`);
    }
  }
  shell.mkdir('-p', 'dist/css');
  shell.mkdir('-p', 'dist/image');

  // compress and write htmls
  for (const html of htmls) {
    if (spec.html_minifier.enable) {
      if (
        !_.some(spec.html_minifier.exclude, o =>
          minimatch(`${html.name}.html`, o))
      ) {
        debug(`compressing ${html.name}.html ...`);
        html.content = await htmlMinify(html.content);
      }
    }
    // append cache-busting query to local CSS references
    html.content = html.content.replace(
      /href="(css\/[^"]+\.css)"/g,
      `href="$1?v=${cacheBust}"`
    );
    debug(`writing ${html.name}.html to file ...`);
    fs.writeFileSync(`dist/${html.name}.html`, html.content);
  }

  // compress and write csses
  const csses = globSync(`themes/${spec.theme}/css/*.css`);

  _.forEach(csses, css => {
    let ret_css = fs.readFileSync(css, 'utf8');
    const css_name = css.slice(css.lastIndexOf('/') + 1, css.lastIndexOf('.'));
    debug(`handling css file: ${css_name}`);
    if (
      spec.css_minifier.enable &&
      !_.some(spec.css_minifier.exclude, o => minimatch(`${css_name}.css`, o))
    ) {
      ret_css = new CleanCSS({ inline: false }).minify(ret_css).styles;
    }
    fs.writeFileSync(`dist/css/${css_name}.css`, ret_css);
  });

  // copy images
  shell.cp('-Rf', `themes/${spec.theme}/image/*`, 'dist/image');

  // generate CNAME
  if (spec.cname) {
    fs.writeFileSync('dist/CNAME', spec.cname);
  }

  shell.echo('Success to generate static files in folder dist!');
}

/**
 * barnServer
 */
async function barnServer(port = 3579) {
  await barnGenerate();
  injectLiveReloadScript();

  const PORT = port;
  let sseClients = [];

  const MIME_TYPES = {
    '.html': 'text/html',
    '.css': 'text/css',
    '.js': 'application/javascript',
    '.json': 'application/json',
    '.png': 'image/png',
    '.jpg': 'image/jpeg',
    '.jpeg': 'image/jpeg',
    '.gif': 'image/gif',
    '.svg': 'image/svg+xml',
    '.ico': 'image/x-icon',
    '.webp': 'image/webp',
  };

  const server = http.createServer((req, res) => {
    if (req.url === '/__livereload') {
      res.writeHead(200, {
        'Content-Type': 'text/event-stream',
        'Cache-Control': 'no-cache',
        'Connection': 'keep-alive',
      });
      res.write('data: connected\n\n');
      sseClients.push(res);
      req.on('close', () => {
        sseClients = sseClients.filter(c => c !== res);
      });
      return;
    }

    let urlPath = req.url.split('?')[0];
    if (urlPath === '/') urlPath = '/index.html';
    const filePath = path.join('dist', urlPath);
    const ext = path.extname(filePath);

    try {
      const content = fs.readFileSync(filePath);
      res.writeHead(200, { 'Content-Type': MIME_TYPES[ext] || 'application/octet-stream' });
      res.end(content);
    } catch {
      res.writeHead(404, { 'Content-Type': 'text/plain' });
      res.end('Not Found');
    }
  });

  server.on('error', (err) => {
    if (err.code === 'EADDRINUSE') {
      echoErrAndExit(`Error: port ${PORT} is already in use. Try: barn server -p <other-port>`);
    } else {
      echoErrAndExit(`Error: ${err.message}`);
    }
  });

  server.listen(PORT, () => {
    const url = `http://localhost:${PORT}`;
    shell.echo(`Server running at ${url}`);
    shell.echo(
      'Watching file changes, any change would be applied immediately! Have Fun!'
    );
    const openCmd = platform() === 'darwin' ? 'open' : platform() === 'win32' ? 'start' : 'xdg-open';
    execCb(`${openCmd} ${url}`);
  });

  chokidar.watch('./', {
    ignored: [/node_modules/, /\.git/, /dist/],
    ignoreInitial: true
  }).on('all', async (event, f) => {
    debug(`${event}: ${f}, regenerating...`);
    try {
      await barnGenerate();
      injectLiveReloadScript();
      sseClients.forEach(client => {
        client.write('data: reload\n\n');
      });
    } catch (e) {
      shell.echo(`Error during regeneration: ${e.message}`);
      shell.echo('Waiting for next file change to retry...');
    }
  });
}

/**
 * inject livereload script into generated HTML files in dist/
 */
function injectLiveReloadScript() {
  const script = `<script>(function(){var es,t;function connect(){es=new EventSource("/__livereload");es.addEventListener("message",function(e){if(e.data==="reload")location.reload()})}connect();var origPrint=window.print;window.print=function(){if(es){es.close();es=null}origPrint.call(window);t=setTimeout(connect,1000)}})()</script>`;
  _.forEach(spec.htmls, name => {
    const filePath = `dist/${name}.html`;
    try {
      let html = fs.readFileSync(filePath, 'utf8');
      if (!html.includes('__livereload')) {
        html = html.replace('</body>', script + '</body>');
        fs.writeFileSync(filePath, html);
      }
    } catch (e) {
      debug(`Failed to inject livereload into ${filePath}: ${e.message}`);
    }
  });
}
